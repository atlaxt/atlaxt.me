{
  "name": "atlaxt.me",
  "type": "module",
  "version": "0.9.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "generate:seo": "node ./scripts/generate-seo-files.mjs",
    "generate:thumbs": "node ./scripts/generate-thumbs.mjs",
    "build": "run-s generate:seo && run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prebuild": "to-public"
  },
  "dependencies": {
    "@unhead/vue": "^2.1.12",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vueuse/core": "^14.2.1",
    "vue": "^3.5.29",
    "vue-i18n": "^10.0.5",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@atlaxt/to-public": "^2.0.0",
    "@tailwindcss/vite": "^4.1.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.11.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.3",
    "npm-run-all2": "^8.0.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vue-tsc": "^3.2.5"
  }
}
